    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "glob": "^13.0.6",
    "nodemailer": "^8.0.2",
    "pinia": "^3.0.4",
    "rimraf": "^6.1.3",
    "sqlite3": "^5.1.7",
    "tar": "^7.5.13",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^24.11.0",
